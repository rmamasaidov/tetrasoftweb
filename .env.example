# tetrasoft.uz — environment variables
#
# Copy this file to `.env` (NEVER commit `.env`) and fill in real values.
# Compose loads `.env` automatically; the `backend` service reads it via env_file.

# ----- Telegram (required for Phase 5 lead pipeline) -----

# Token from @BotFather (e.g. "1234567890:AAH...")
TELEGRAM_BOT_TOKEN=

# Numeric chat ID of the admin who receives lead notifications.
# To find your own ID, message @userinfobot on Telegram.
TELEGRAM_ADMIN_CHAT_ID=

# ----- Backend tuning (defaults are fine; uncomment to override) -----

# NODE_ENV=production
# PORT=3000
# SQLITE_FILE=/data/leads.db

# ----- SMTP for forwarding leads to email (optional; Phase 5+) -----
# If left blank, lead forwarding is Telegram-only.

# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_TO=tetrasoft@mail.ru
