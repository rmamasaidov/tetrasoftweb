---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  /** Header style: transparent over a dark hero (homepage, about, etc.) or solid white. */
  overHero?: boolean;
  /** Canonical override; defaults to current URL based on site config. */
  canonical?: string;
  /** Optional og:image (absolute URL preferred). */
  ogImage?: string;
  /** Breadcrumb trail (omit Home — it's prepended automatically). */
  breadcrumbs?: Array<{ name: string; url: string }>;
  /** Extra JSON-LD blocks to emit (e.g. SoftwareApplication on portfolio detail). */
  jsonLd?: Array<Record<string, unknown>>;
  lang?: string;
}

const {
  title,
  description,
  overHero = false,
  canonical,
  ogImage,
  breadcrumbs,
  jsonLd = [],
  lang = 'ru',
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://tetrasoft.uz';
const pageUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const currentPath = Astro.url.pathname;

const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "TETRASOFT",
  "legalName": "ООО «TETRASOFT»",
  "url": siteUrl,
  "foundingDate": "1997-11-28",
  "telephone": "+998712407805",
  "email": "info@tetrasoft.uz",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Каракамыш-1/3, 35, оф. 5",
    "addressLocality": "Ташкент",
    "addressRegion": "Алмазарский район",
    "postalCode": "100098",
    "addressCountry": "UZ"
  },
  "taxID": "202430867",
  "areaServed": "UZ",
  "description": "Разработка корпоративных и государственных информационных систем в Узбекистане. Резидент IT Park."
};

const breadcrumbsJsonLd = breadcrumbs && breadcrumbs.length
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": siteUrl + '/' },
        ...breadcrumbs.map((b, i) => ({
          "@type": "ListItem",
          "position": i + 2,
          "name": b.name,
          "item": b.url.startsWith('http') ? b.url : siteUrl + b.url,
        })),
      ],
    }
  : null;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="TETRASOFT" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:locale" content="ru_RU" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <meta name="theme-color" content="#0A1330" />

    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    {breadcrumbsJsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbsJsonLd)} />
    )}
    {jsonLd.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </head>

  <body>
    <a href="#main-content" class="skip-link">Перейти к основному содержанию</a>

    <Header overHero={overHero} currentPath={currentPath} />

    <main id="main-content">
      <slot />
    </main>

    <Footer />

    <script>
      // Scroll fade-in for elements with .fade-in
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          }
        }, { rootMargin: '0px 0px -80px 0px', threshold: 0.05 });
        document.querySelectorAll('.fade-in').forEach((el) => io.observe(el));
      } else {
        document.querySelectorAll('.fade-in').forEach((el) => el.classList.add('is-visible'));
      }
    </script>

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--brand-dark);
        color: var(--text-on-dark);
        padding: 0.75rem 1rem;
        z-index: 100;
        border-radius: 0 0 var(--radius-md) 0;
      }
      .skip-link:focus { left: 0; }
    </style>
  </body>
</html>
