---
import SectionEyebrow from './SectionEyebrow.astro';
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__bg" aria-hidden="true">
    <!-- Brand-gradient fallback (also shows behind video while it loads) -->
    <div class="hero__gradient"></div>

    <!-- Poster always present; covers full bg. On mobile (and reduced-motion) this is the entire visual. -->
    <img
      class="hero__poster"
      src="/video/hero-poster.jpg"
      alt=""
      width="1920"
      height="1080"
      decoding="async"
      fetchpriority="high"
    />

    <!-- Video mount point; JS injects <video> only on viewports ≥720px with motion allowed -->
    <div class="hero__video-mount" data-hero-video data-poster="/video/hero-poster.jpg"></div>

    <!-- Bottom-to-top fade for legibility -->
    <div class="hero__scrim"></div>
  </div>

  <div class="container-x hero__inner">
    <SectionEyebrow text="Резидент IT Park · с 1997 года" onDark={true} />
    <h1 id="hero-title" class="hero__title">
      Информационные системы для государства и бизнеса
    </h1>
    <p class="hero__sub">
      28 лет создаём решения, которым доверяют крупнейшие государственные органы Узбекистана
    </p>
    <div class="hero__cta">
      <a href="#contact" class="btn btn-primary">Обсудить проект</a>
      <a href="/portfolio" class="btn btn-outline-on-dark">Портфолио →</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    color: var(--text-on-dark);
    min-height: clamp(540px, 88vh, 760px);
    display: flex;
    align-items: center;
    overflow: hidden;
    margin-top: -72px;
    padding-top: 72px;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: var(--brand-dark);
  }

  .hero__gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 20% 40%, rgba(25, 113, 194, 0.35) 0%, transparent 60%),
      radial-gradient(ellipse 70% 70% at 80% 70%, rgba(28, 46, 111, 0.55) 0%, transparent 60%),
      linear-gradient(160deg, #0A1330 0%, #060B22 70%, #0A1330 100%);
  }

  .hero__poster,
  .hero__video-mount video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Tone the bright bg so foreground copy reads cleanly */
    opacity: 0.55;
    mix-blend-mode: screen;
  }

  /* Video, once injected, sits above the poster */
  .hero__video-mount video { z-index: 1; }

  .hero__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(10, 19, 48, 0.25) 0%, transparent 30%, rgba(6, 11, 34, 0.6) 100%);
    z-index: 2;
  }

  .hero__inner {
    width: 100%;
    max-width: 980px;
    position: relative;
  }

  .hero__title {
    color: var(--text-on-dark);
    margin-top: 1.25rem;
    font-size: clamp(2rem, 3.6vw + 1rem, 3.5rem);
    max-width: 22ch;
    line-height: 1.08;
  }

  .hero__sub {
    color: var(--text-on-dark-muted);
    max-width: 56ch;
    margin-top: 1.5rem;
    font-size: clamp(1rem, 0.4vw + 0.95rem, 1.125rem);
  }

  .hero__cta {
    margin-top: 2.5rem;
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  @media (max-width: 540px) {
    .hero { min-height: 560px; }
    .hero__cta .btn { flex: 1 1 auto; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__video-mount video { display: none; }
  }
</style>

<script>
  // Only inject the video on viewports ≥720px AND when motion is allowed.
  // Mobile and reduced-motion users get the poster only — no video bytes downloaded.
  const mount = document.querySelector<HTMLElement>('[data-hero-video]');
  const canMotion = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const wideEnough = window.matchMedia('(min-width: 720px)').matches;
  if (mount && canMotion && wideEnough) {
    const poster = mount.dataset.poster ?? '';
    const video = document.createElement('video');
    video.autoplay = true;
    video.muted = true;
    video.loop = true;
    video.playsInline = true;
    video.preload = 'metadata';
    if (poster) video.poster = poster;
    video.setAttribute('aria-hidden', 'true');

    const webm = document.createElement('source');
    webm.src = '/video/hero.webm';
    webm.type = 'video/webm';
    const mp4 = document.createElement('source');
    mp4.src = '/video/hero.mp4';
    mp4.type = 'video/mp4';
    video.append(webm, mp4);

    mount.appendChild(video);
  }
</script>
