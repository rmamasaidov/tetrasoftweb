---
import SectionEyebrow from './SectionEyebrow.astro';
import Icon from './Icon.astro';

type IconName = 'shield-check' | 'cpu' | 'school' | 'stethoscope' | 'building-skyscraper' | 'tractor';

const projects: Array<{
  slug: string;
  title: string;
  client: string;
  year: string;
  summary: string;
  award?: string;
  sectorLabel: string;
  sectorKey: 'gov' | 'industry' | 'edu' | 'health';
  icon: IconName;
}> = [
  {
    slug: 'gtk-narusheniya',
    title: 'АИС «Учёт нарушений таможенного законодательства»',
    client: 'Государственный таможенный комитет',
    year: '2010',
    summary: 'Единая автоматизированная система учёта таможенных правонарушений с возможностью аналитики и отчётности.',
    award: 'Награда',
    sectorLabel: 'Государство',
    sectorKey: 'gov',
    icon: 'shield-check',
  },
  {
    slug: 'ts-scale',
    title: 'TS_Scale — Платформа автоматического взвешивания',
    client: 'ГТК «Яллама», АПК, отходы',
    year: '2019–2022',
    summary: 'Платформа автоматического взвешивания транспорта с распознаванием номеров. Внедрена на 3 типах объектов.',
    sectorLabel: 'Промышленность',
    sectorKey: 'industry',
    icon: 'building-skyscraper',
  },
  {
    slug: 'nacionalnye-imena',
    title: 'Электронная платформа национальных имён',
    client: 'Центр обучения государственному языку',
    year: '2022',
    summary: 'Цифровая платформа для систематизации и публикации национальных имён с поиском и фильтрацией.',
    sectorLabel: 'Государство',
    sectorKey: 'gov',
    icon: 'school',
  },
  {
    slug: 'med-ais',
    title: 'Комплексная цифровая АИС для медицинских учреждений',
    client: 'Медицинские учреждения',
    year: '2020',
    summary: 'Ведение медицинских данных, регистрация, учёт услуг, документооборот.',
    sectorLabel: 'Здравоохранение',
    sectorKey: 'health',
    icon: 'stethoscope',
  },
];
---

<section class="portfolio-featured section-pad" aria-labelledby="portfolio-title">
  <div class="container-x">
    <header class="portfolio-featured__header fade-in">
      <SectionEyebrow text="ПОРТФОЛИО" />
      <h2 id="portfolio-title" class="portfolio-featured__h2">
        Системы, работающие в государственных учреждениях и крупном бизнесе
      </h2>
    </header>

    <ul class="portfolio-featured__grid fade-in">
      {projects.map((p) => (
        <li>
          <a href={`/portfolio/${p.slug}`} class:list={["project-card", `project-card--${p.sectorKey}`]}>
            <div class="project-card__visual" aria-hidden="true">
              <Icon name={p.icon} size={44} class="project-card__visual-icon" />
              <span class="project-card__visual-label">{p.sectorLabel}</span>
              {p.award && <span class="project-card__visual-award">{p.award}</span>}
            </div>

            <div class="project-card__body">
              <div class="project-card__meta">
                <span class="project-card__year">{p.year}</span>
                <span class="project-card__client">{p.client}</span>
              </div>
              <h3 class="project-card__title">{p.title}</h3>
              <p class="project-card__summary">{p.summary}</p>
              <span class="project-card__link">Подробнее <Icon name="arrow-right" size={16} /></span>
            </div>
          </a>
        </li>
      ))}
    </ul>

    <div class="portfolio-featured__cta fade-in">
      <a href="/portfolio" class="btn btn-primary">Все проекты →</a>
    </div>
  </div>
</section>

<style>
  .portfolio-featured { background: var(--bg-white); }

  .portfolio-featured__header {
    margin-bottom: 2.5rem;
    max-width: 760px;
  }
  .portfolio-featured__h2 { margin-top: 0.75rem; }

  .portfolio-featured__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-white);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    height: 100%;
    color: inherit;
  }

  .project-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
    border-color: color-mix(in srgb, var(--brand-blue) 25%, var(--border-light));
  }

  /* Gradient + icon band replaces a photo */
  .project-card__visual {
    position: relative;
    padding: 1.75rem 1.5rem;
    min-height: 160px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: var(--text-on-dark);
    isolation: isolate;
  }

  /* Per-sector gradients — culturally neutral, brand-aligned */
  .project-card--gov .project-card__visual {
    background:
      radial-gradient(ellipse 70% 60% at 80% 20%, rgba(133, 183, 235, 0.35) 0%, transparent 60%),
      linear-gradient(135deg, #0A1330 0%, #1C2E6F 100%);
  }
  .project-card--industry .project-card__visual {
    background:
      radial-gradient(ellipse 70% 60% at 20% 80%, rgba(25, 113, 194, 0.35) 0%, transparent 60%),
      linear-gradient(135deg, #1C2E6F 0%, #0A1330 60%, #1971C2 130%);
  }
  .project-card--edu .project-card__visual {
    background:
      radial-gradient(ellipse 60% 60% at 80% 30%, rgba(93, 202, 165, 0.3) 0%, transparent 60%),
      linear-gradient(135deg, #1C2E6F 0%, #0A1330 100%);
  }
  .project-card--health .project-card__visual {
    background:
      radial-gradient(ellipse 60% 60% at 25% 25%, rgba(93, 202, 165, 0.32) 0%, transparent 60%),
      linear-gradient(135deg, #0A1330 0%, #1C2E6F 100%);
  }

  .project-card__visual-icon {
    color: var(--brand-blue-light);
    opacity: 0.9;
  }

  .project-card__visual-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-on-dark-muted);
  }

  .project-card__visual-award {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--brand-dark);
    background: var(--brand-accent);
    padding: 0.3125rem 0.625rem;
    border-radius: 9999px;
  }

  .project-card__body {
    padding: 1.5rem 1.75rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex-grow: 1;
  }

  .project-card__meta {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    flex-wrap: wrap;
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }
  .project-card__year {
    color: var(--brand-blue);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .project-card__client::before { content: '·'; margin-right: 0.5rem; color: var(--border-light); }

  .project-card__title {
    font-size: 1.1875rem;
    margin: 0.125rem 0 0;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .project-card__summary {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.55;
    flex-grow: 1;
  }

  .project-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--brand-blue);
    font-weight: 500;
    font-size: 0.9375rem;
    margin-top: 0.5rem;
  }
  .project-card:hover .project-card__link { gap: 0.625rem; }

  .portfolio-featured__cta {
    margin-top: 2.5rem;
    text-align: center;
  }

  @media (max-width: 760px) {
    .portfolio-featured__grid { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card { transition: none; }
    .project-card:hover { transform: none; }
    .project-card:hover .project-card__link { gap: 0.375rem; }
  }
</style>
