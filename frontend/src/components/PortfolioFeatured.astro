---
import { getCollection } from 'astro:content';
import SectionEyebrow from './SectionEyebrow.astro';
import PortfolioCard from './PortfolioCard.astro';

// 4 cards in the order called out on the homepage:
const order = ['gtk-narusheniya', 'ts-scale', 'nacionalnye-imena', 'med-ais'];
const all = await getCollection('portfolio');
const projects = order
  .map((s) => all.find((p) => p.slug === s))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));
---

<section class="portfolio-featured section-pad" aria-labelledby="portfolio-title">
  <div class="container-x">
    <header class="portfolio-featured__header fade-in">
      <SectionEyebrow text="ПОРТФОЛИО" />
      <h2 id="portfolio-title" class="portfolio-featured__h2">
        Системы, работающие в государственных учреждениях и крупном бизнесе
      </h2>
    </header>

    <ul class="portfolio-featured__grid fade-in">
      {projects.map((p) => (
        <li>
          <PortfolioCard
            slug={p.data.slug}
            title={p.data.title}
            client={p.data.client}
            year={p.data.year}
            summary={p.data.summary}
            sector={p.data.sector}
            award={p.data.award}
          />
        </li>
      ))}
    </ul>

    <div class="portfolio-featured__cta fade-in">
      <a href="/portfolio" class="btn btn-primary">Все проекты →</a>
    </div>
  </div>
</section>

<style>
  .portfolio-featured { background: var(--bg-white); }
  .portfolio-featured__header { margin-bottom: 2.5rem; max-width: 760px; }
  .portfolio-featured__h2 { margin-top: 0.75rem; }
  .portfolio-featured__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  .portfolio-featured__cta { margin-top: 2.5rem; text-align: center; }

  @media (max-width: 760px) {
    .portfolio-featured__grid { grid-template-columns: 1fr; }
  }
</style>
