---
import Icon from './Icon.astro';
import { SECTOR_SHORT, SECTOR_VISUAL, SECTOR_ICON, type SectorKey } from '../lib/sectors';

interface Props {
  slug: string;
  title: string;
  client: string;
  year: string;
  summary: string;
  dgu?: string;
  sector: SectorKey;
  award?: string;
}
const { slug, title, client, year, summary, dgu, sector, award } = Astro.props;
const visual = SECTOR_VISUAL[sector];
const icon = SECTOR_ICON[sector] as
  | 'shield-check' | 'building-skyscraper' | 'cpu' | 'refresh' | 'headset'
  | 'building-bank' | 'businessplan' | 'tractor' | 'stethoscope' | 'school';
const sectorLabel = SECTOR_SHORT[sector];
---

<a href={`/portfolio/${slug}`} class:list={["project-card", `project-card--${visual}`]} data-sector={sector}>
  <div class="project-card__visual" aria-hidden="true">
    <Icon name={icon} size={40} class="project-card__visual-icon" />
    <span class="project-card__visual-label">{sectorLabel}</span>
    {award && <span class="project-card__visual-award">Награда</span>}
  </div>

  <div class="project-card__body">
    <div class="project-card__meta">
      <span class="project-card__year">{year}</span>
      <span class="project-card__client">{client}</span>
    </div>
    <h3 class="project-card__title">{title}</h3>
    <p class="project-card__summary">{summary}</p>
    {dgu && <p class="project-card__dgu">{dgu}</p>}
    <span class="project-card__link">Подробнее <Icon name="arrow-right" size={16} /></span>
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-white);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    height: 100%;
    color: inherit;
  }
  .project-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
    border-color: color-mix(in srgb, var(--brand-blue) 25%, var(--border-light));
  }

  .project-card__visual {
    position: relative;
    padding: 1.5rem 1.25rem;
    min-height: 140px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: var(--text-on-dark);
    isolation: isolate;
  }
  .project-card--gov .project-card__visual {
    background:
      radial-gradient(ellipse 70% 60% at 80% 20%, rgba(133, 183, 235, 0.35) 0%, transparent 60%),
      linear-gradient(135deg, #0A1330 0%, #1C2E6F 100%);
  }
  .project-card--industry .project-card__visual {
    background:
      radial-gradient(ellipse 70% 60% at 20% 80%, rgba(25, 113, 194, 0.35) 0%, transparent 60%),
      linear-gradient(135deg, #1C2E6F 0%, #0A1330 60%, #1971C2 130%);
  }
  .project-card--edu .project-card__visual {
    background:
      radial-gradient(ellipse 60% 60% at 80% 30%, rgba(93, 202, 165, 0.3) 0%, transparent 60%),
      linear-gradient(135deg, #1C2E6F 0%, #0A1330 100%);
  }
  .project-card--health .project-card__visual {
    background:
      radial-gradient(ellipse 60% 60% at 25% 25%, rgba(93, 202, 165, 0.32) 0%, transparent 60%),
      linear-gradient(135deg, #0A1330 0%, #1C2E6F 100%);
  }

  .project-card__visual-icon { color: var(--brand-blue-light); opacity: 0.9; }

  .project-card__visual-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-on-dark-muted);
  }

  .project-card__visual-award {
    position: absolute;
    top: 0.875rem;
    right: 0.875rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--brand-dark);
    background: var(--brand-accent);
    padding: 0.3125rem 0.625rem;
    border-radius: 9999px;
  }

  .project-card__body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex-grow: 1;
  }

  .project-card__meta {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.75rem;
    color: var(--text-secondary);
  }
  .project-card__year {
    color: var(--brand-blue);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .project-card__client::before { content: '·'; margin-right: 0.4rem; color: var(--border-light); }

  .project-card__title {
    font-size: 1.0625rem;
    margin: 0.125rem 0 0;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .project-card__summary {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.55;
    flex-grow: 1;
  }

  .project-card__dgu {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin: 0.25rem 0 0;
  }

  .project-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--brand-blue);
    font-weight: 500;
    font-size: 0.9375rem;
    margin-top: 0.5rem;
  }
  .project-card:hover .project-card__link { gap: 0.625rem; }

  @media (prefers-reduced-motion: reduce) {
    .project-card { transition: none; }
    .project-card:hover { transform: none; }
    .project-card:hover .project-card__link { gap: 0.375rem; }
  }
</style>
