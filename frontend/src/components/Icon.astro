---
/* Inline SVG icon set (Tabler-style 1.5px stroke).
   Add new icons here as needed; keep the visual weight uniform. */
interface Props {
  name:
    | 'shield-check'
    | 'building-skyscraper'
    | 'cpu'
    | 'refresh'
    | 'headset'
    | 'building-bank'
    | 'businessplan'
    | 'tractor'
    | 'stethoscope'
    | 'school'
    | 'arrow-right'
    | 'check';
  size?: number;
  class?: string;
  ariaLabel?: string;
}
const { name, size = 24, class: className = '', ariaLabel } = Astro.props;
const a11y = ariaLabel
  ? { role: 'img', 'aria-label': ariaLabel }
  : { 'aria-hidden': 'true' };
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  {...a11y}
>
  {name === 'shield-check' && (
    <>
      <path d="M12 3l8 3v6c0 5-3.5 8.5-8 9-4.5-.5-8-4-8-9V6l8-3z" />
      <path d="M9 12l2 2 4-4" />
    </>
  )}
  {name === 'building-skyscraper' && (
    <>
      <path d="M3 21h18" />
      <path d="M5 21V7l8-4v18" />
      <path d="M19 21V11l-6-4" />
      <path d="M9 9v.01" /><path d="M9 12v.01" /><path d="M9 15v.01" /><path d="M9 18v.01" />
    </>
  )}
  {name === 'cpu' && (
    <>
      <rect x="5" y="5" width="14" height="14" rx="1" />
      <rect x="9" y="9" width="6" height="6" />
      <path d="M3 10h2" /><path d="M3 14h2" />
      <path d="M19 10h2" /><path d="M19 14h2" />
      <path d="M10 3v2" /><path d="M14 3v2" />
      <path d="M10 19v2" /><path d="M14 19v2" />
    </>
  )}
  {name === 'refresh' && (
    <>
      <path d="M20 11A8 8 0 0 0 6.3 6.3L4 8" />
      <path d="M4 4v4h4" />
      <path d="M4 13a8 8 0 0 0 13.7 4.7L20 16" />
      <path d="M20 20v-4h-4" />
    </>
  )}
  {name === 'headset' && (
    <>
      <path d="M4 14v-3a8 8 0 0 1 16 0v3" />
      <path d="M18 19c0 1.1-.9 2-2 2h-2v-7h4z" />
      <path d="M6 14H4v5a2 2 0 0 0 2 2h2v-7H6z" />
    </>
  )}
  {name === 'building-bank' && (
    <>
      <path d="M3 21h18" />
      <path d="M3 10h18" />
      <path d="M5 6l7-3 7 3" />
      <path d="M4 10v11" /><path d="M20 10v11" />
      <path d="M8 14v3" /><path d="M12 14v3" /><path d="M16 14v3" />
    </>
  )}
  {name === 'businessplan' && (
    <>
      <path d="M9 11l3 3 5-5" />
      <path d="M3 3v18h18" />
      <path d="M7 17v-3" /><path d="M11 17v-2" /><path d="M15 17v-4" /><path d="M19 17V9" />
    </>
  )}
  {name === 'tractor' && (
    <>
      <circle cx="7" cy="17" r="3" />
      <circle cx="17" cy="17" r="2" />
      <path d="M4 17H3v-3l2-3h4l3-4h4l1 5" />
      <path d="M15 17h-5" />
    </>
  )}
  {name === 'stethoscope' && (
    <>
      <path d="M6 4h-1a2 2 0 0 0-2 2v4a4 4 0 0 0 4 4 4 4 0 0 0 4-4V6a2 2 0 0 0-2-2h-1" />
      <path d="M8 14v3a4 4 0 1 0 8 0v-1" />
      <circle cx="16" cy="13" r="2" />
    </>
  )}
  {name === 'school' && (
    <>
      <path d="M22 9L12 5 2 9l10 4 10-4v6" />
      <path d="M6 10.5V16c0 1.5 3 3 6 3s6-1.5 6-3v-5.5" />
    </>
  )}
  {name === 'arrow-right' && (
    <>
      <path d="M5 12h14" />
      <path d="M13 6l6 6-6 6" />
    </>
  )}
  {name === 'check' && (
    <path d="M5 12l5 5L20 7" />
  )}
</svg>
