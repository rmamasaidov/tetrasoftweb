---
import SectionEyebrow from './SectionEyebrow.astro';
import Icon from './Icon.astro';

const topRow = [
  {
    variant: 'dark' as const,
    icon: 'shield-check' as const,
    title: 'Государственные IT-решения',
    text: 'Автоматизация процессов министерств и ведомств. С Государственным таможенным комитетом работаем с 2010 года — четыре информационные системы.',
    href: '/services/gosudarstvennye-resheniya',
  },
  {
    variant: 'light' as const,
    icon: 'building-skyscraper' as const,
    title: 'Корпоративная разработка',
    text: 'ERP, CRM, системы учёта под задачи бизнеса.',
    href: '/services/korporativnaya-razrabotka',
  },
];

const bottomRow = [
  {
    icon: 'cpu' as const,
    tint: 'var(--tint-mint)',
    title: 'AI-интеграция',
    text: 'Машинное обучение в процессах',
    href: '/services/ai-integraciya',
  },
  {
    icon: 'refresh' as const,
    tint: 'var(--tint-sand)',
    title: 'Модернизация',
    text: 'Перевод legacy на новые платформы',
    href: '/services/modernizaciya-legacy',
  },
  {
    icon: 'headset' as const,
    tint: 'var(--tint-lavender)',
    title: 'Поддержка',
    text: 'Долгосрочное сопровождение',
    href: '/services/tehnicheskaya-podderzhka',
  },
];
---

<section class="services section-pad" aria-labelledby="services-title">
  <div class="container-x">
    <header class="services__header fade-in">
      <SectionEyebrow text="НАШИ КОМПЕТЕНЦИИ" />
      <h2 id="services-title" class="services__h2">Полный цикл разработки</h2>
    </header>

    <div class="services__top fade-in">
      {topRow.map((card) => (
        <a href={card.href} class:list={["service", card.variant === 'dark' ? 'service--dark' : 'service--light']}>
          <div class="service__icon-wrap">
            <Icon name={card.icon} size={28} class="service__icon" />
          </div>
          <h3 class="service__title">{card.title}</h3>
          <p class="service__text">{card.text}</p>
          <span class="service__link">Подробнее <Icon name="arrow-right" size={16} /></span>
        </a>
      ))}
    </div>

    <div class="services__bottom fade-in">
      {bottomRow.map((card) => (
        <a href={card.href} class="service service--light service--compact">
          <div class="service__icon-wrap" style={`background: ${card.tint};`}>
            <Icon name={card.icon} size={24} class="service__icon service__icon--tinted" />
          </div>
          <h3 class="service__title">{card.title}</h3>
          <p class="service__text">{card.text}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    background: var(--bg-white);
  }

  .services__header {
    text-align: left;
    margin-bottom: 2.5rem;
    max-width: 760px;
  }
  .services__h2 {
    margin-top: 0.75rem;
  }

  .services__top {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .services__bottom {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .service {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-light);
    background: var(--bg-white);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    min-height: 220px;
    color: inherit;
  }

  .service:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
    border-color: color-mix(in srgb, var(--brand-blue) 25%, var(--border-light));
  }

  .service--dark {
    background: var(--brand-dark);
    color: var(--text-on-dark);
    border-color: var(--border-dark);
    min-height: 280px;
  }

  .service--dark:hover {
    border-color: rgba(255, 255, 255, 0.16);
  }

  .service__icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    background: rgba(25, 113, 194, 0.10);
    color: var(--brand-blue);
    flex-shrink: 0;
  }

  .service--dark .service__icon-wrap {
    background: rgba(133, 183, 235, 0.14);
    color: var(--brand-blue-light);
  }

  .service__icon--tinted {
    color: var(--brand-navy);
  }

  .service__title {
    font-size: 1.25rem;
    margin: 0;
    color: inherit;
  }

  .service--compact .service__title {
    font-size: 1.0625rem;
  }

  .service--dark .service__title { color: var(--text-on-dark); }

  .service__text {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.55;
    margin: 0;
    flex-grow: 1;
  }

  .service--dark .service__text { color: var(--text-on-dark-muted); }

  .service__link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--brand-blue);
    font-weight: 500;
    font-size: 0.9375rem;
    margin-top: 0.5rem;
  }

  .service--dark .service__link { color: var(--brand-blue-light); }

  .service:hover .service__link { gap: 0.625rem; }

  @media (max-width: 880px) {
    .services__top { grid-template-columns: 1fr; }
    .services__bottom { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .service { transition: none; }
    .service:hover { transform: none; }
    .service:hover .service__link { gap: 0.375rem; }
  }
</style>
