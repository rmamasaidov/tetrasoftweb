---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import SectionEyebrow from '../../components/SectionEyebrow.astro';
import Icon from '../../components/Icon.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import FinalCTA from '../../components/FinalCTA.astro';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);

const intro = [
  'TETRASOFT специализируется на сложных информационных системах, где требуется не только программирование, но и понимание регуляторных требований, отраслевой специфики и интеграции с государственными системами. Мы не делаем простые сайты-визитки или мобильные приложения для розничного потребителя — наша компетенция в другой области.',
  'Каждый проект ведёт команда экспертов с многолетним опытом работы в IT и привлечением профильных специалистов под конкретную задачу. Это позволяет масштабировать ресурсы под требования проекта, не теряя в качестве и контроле.',
];

const notDoing = [
  'Сайты-визитки, лендинги, типовые корпоративные сайты',
  'Мобильные приложения для розничного потребительского сегмента',
  'Игры и развлекательный контент',
  'Fintech-продукты для массового рынка',
  'Outsourcing-разработка по моделям почасовой оплаты',
];

type ServiceIcon =
  | 'shield-check' | 'building-skyscraper' | 'cpu' | 'refresh' | 'headset';
---

<BaseLayout
  title="Услуги — TETRASOFT"
  description="Услуги TETRASOFT: государственные IT-решения, корпоративная разработка, AI-интеграция, модернизация legacy-систем, техническая поддержка."
  overHero={true}
>
  <PageHero
    eyebrow="УСЛУГИ"
    title="Полный цикл разработки информационных систем"
    subtitle="От анализа задачи до долгосрочного сопровождения. Работаем с госсектором с 2010 года, с корпоративным сегментом — с момента основания."
  />

  <section class="services-intro section-pad">
    <div class="container-x services-intro__inner fade-in">
      {intro.map((p) => <p>{p}</p>)}
    </div>
  </section>

  <section class="services-list section-pad" aria-labelledby="services-list-title">
    <div class="container-x">
      <h2 id="services-list-title" class="sr-only">Перечень услуг</h2>
      <ul class="services-list__items">
        {services.map((s) => (
          <li class="srv-card fade-in">
            <div class="srv-card__icon-wrap">
              <Icon name={s.data.icon as ServiceIcon} size={32} />
            </div>
            <div class="srv-card__body">
              <h3 class="srv-card__title">{s.data.title}</h3>
              <p class="srv-card__desc">{s.data.shortDescription}</p>
              <p class="srv-card__target"><strong>Для кого:</strong> {s.data.targetClient}</p>
              <a href={`/services/${s.data.slug}`} class="btn btn-ghost srv-card__link">
                Подробнее <Icon name="arrow-right" size={16} />
              </a>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="not-doing section-pad" aria-labelledby="not-doing-title">
    <div class="container-x">
      <header class="not-doing__header fade-in">
        <SectionEyebrow text="ВАЖНО ПОНИМАТЬ" />
        <h2 id="not-doing-title">Чего мы не делаем</h2>
        <p class="not-doing__sub">
          Чтобы избежать недопонимания — наша компетенция в одной области, и есть направления, которые мы не развиваем.
        </p>
      </header>
      <ul class="not-doing__list fade-in">
        {notDoing.map((item) => (
          <li class="not-doing__item">
            <span class="not-doing__mark" aria-hidden="true">✕</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
      <p class="not-doing__note">Это позволяет нам работать на высоком уровне в выбранном сегменте.</p>
    </div>
  </section>

  <ProcessSteps />

  <FinalCTA
    title="Не нашли свою задачу в списке?"
    text="Перечисленные услуги покрывают большинство задач, с которыми к нам обращаются. Но возможны и более узкие или специфические задачи. Опишите вашу ситуацию — оценим возможности и предложим решение."
    buttonLabel="Описать задачу"
  />
</BaseLayout>

<style>
  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
  }

  .services-intro { background: var(--bg-white); padding-block: clamp(2.5rem, 4vw, 4rem); }
  .services-intro__inner {
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.7;
  }

  .services-list { background: var(--bg-white); padding-top: 0; }
  .services-list__items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .srv-card {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1.5rem;
    padding: 2rem;
    background: var(--bg-white);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .srv-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
    border-color: color-mix(in srgb, var(--brand-blue) 25%, var(--border-light));
  }
  .srv-card__icon-wrap {
    width: 64px; height: 64px;
    border-radius: var(--radius-md);
    background: rgba(25, 113, 194, 0.10);
    color: var(--brand-blue);
    display: inline-flex; align-items: center; justify-content: center;
  }
  .srv-card__body { display: flex; flex-direction: column; gap: 0.5rem; }
  .srv-card__title { font-size: 1.375rem; margin: 0; }
  .srv-card__desc { color: var(--text-secondary); margin: 0; line-height: 1.55; }
  .srv-card__target {
    font-size: 0.875rem; color: var(--text-secondary); margin: 0.25rem 0 0;
  }
  .srv-card__target strong { color: var(--text-primary); font-weight: 600; }
  .srv-card__link { margin-top: 0.5rem; align-self: flex-start; }

  .not-doing { background: var(--bg-light); }
  .not-doing__header { max-width: 760px; margin-bottom: 1.75rem; }
  .not-doing__header h2 { margin-top: 0.75rem; }
  .not-doing__sub { color: var(--text-secondary); margin-top: 0.75rem; max-width: 60ch; }
  .not-doing__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    max-width: 720px;
  }
  .not-doing__item {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 0.875rem 1.25rem;
    background: var(--bg-white);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-size: 0.9375rem;
  }
  .not-doing__mark {
    color: var(--text-secondary);
    font-weight: 600;
    line-height: 1.5;
    flex-shrink: 0;
  }
  .not-doing__note { color: var(--text-secondary); font-size: 0.8125rem; margin-top: 1.5rem; }

  @media (max-width: 640px) {
    .srv-card { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .srv-card { transition: none; }
    .srv-card:hover { transform: none; }
  }
</style>
