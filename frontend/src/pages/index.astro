---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroVideo from '../components/HeroVideo.astro';
import StatsBar from '../components/StatsBar.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import SegmentsBlock from '../components/SegmentsBlock.astro';
import PortfolioFeatured from '../components/PortfolioFeatured.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import TrustLogos from '../components/TrustLogos.astro';
import AboutBrief from '../components/AboutBrief.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout
  title="TETRASOFT — Корпоративная и государственная разработка ПО в Узбекистане"
  description="Разработка информационных систем для государственных органов и крупного бизнеса Узбекистана с 1997 года. Резидент IT Park. 17+ зарегистрированных программных продуктов."
  overHero={true}
>
  <HeroVideo />
  <StatsBar />
  <ServicesGrid />
  <SegmentsBlock />
  <PortfolioFeatured />
  <ProcessSteps />
  <TrustLogos />
  <AboutBrief />
  <CTASection />
</BaseLayout>
