---
import Layout from '../layouts/Layout.astro';
import { t, type Locale } from '../i18n';

const lang: Locale = 'ru';
---

<Layout title={`${t(lang, 'site.title')} — ${t(lang, 'site.tagline')}`} lang={lang}>
  <main class="mx-auto max-w-3xl px-6 py-24">
    <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">
      {t(lang, 'hero.heading')}
    </h1>
    <p class="mt-6 text-lg text-slate-600">
      {t(lang, 'site.tagline')}
    </p>
    <a
      href="#contact"
      class="mt-10 inline-block rounded-md bg-slate-900 px-6 py-3 text-sm font-medium text-white hover:bg-slate-700 transition-colors"
    >
      {t(lang, 'hero.cta')}
    </a>
  </main>

  <footer class="border-t border-slate-200 mt-24 py-8 text-center text-sm text-slate-500">
    {t(lang, 'footer.copy')}
  </footer>
</Layout>
