---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import PortfolioCard from '../../components/PortfolioCard.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import { SECTOR_LABELS, type SectorKey } from '../../lib/sectors';

// Sort: featured first, then by year (newest first).
const yearStart = (y: string) => parseInt(y.match(/^\d{4}/)?.[0] ?? '0', 10);
const projects = (await getCollection('portfolio')).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return yearStart(b.data.year) - yearStart(a.data.year);
});

const sectorsInUse = Array.from(new Set(projects.map((p) => p.data.sector))) as SectorKey[];
const filters: Array<{ key: 'all' | SectorKey; label: string; count: number }> = [
  { key: 'all', label: 'Все', count: projects.length },
  ...sectorsInUse.map((s) => ({
    key: s,
    label: SECTOR_LABELS[s],
    count: projects.filter((p) => p.data.sector === s).length,
  })),
];

const stats = [
  { value: '18', label: 'ПРОЕКТОВ' },
  { value: '17', suffix: '+', label: 'DGU-СЕРТИФИКАТОВ' },
  { value: '6', label: 'ОТРАСЛЕЙ' },
  { value: 'с 2010', label: 'РАБОТАЕМ С ГОССЕКТОРОМ' },
];
---

<BaseLayout
  title="Портфолио — TETRASOFT"
  description="18 реализованных проектов TETRASOFT: государственные информационные системы, корпоративные ERP, AI-решения. Заказчики — ГТК, Минобразования, центр госязыка, АПК."
  overHero={true}
>
  <PageHero
    eyebrow="ПОРТФОЛИО"
    title="18 проектов в 6 отраслях"
    subtitle="Реализованные информационные системы для государственных органов и крупного бизнеса Узбекистана. Все продукты зарегистрированы в Государственном реестре."
  />

  <section class="pf-stats" aria-label="Цифры по портфолио">
    <div class="container-x">
      <ul class="pf-stats__grid">
        {stats.map((s) => (
          <li class="pf-stats__item">
            <div class="pf-stats__number">
              {s.value}{s.suffix && <span class="pf-stats__plus">{s.suffix}</span>}
            </div>
            <div class="pf-stats__label">{s.label}</div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="pf-list section-pad" aria-labelledby="pf-list-title">
    <div class="container-x">
      <h2 id="pf-list-title" class="sr-only">Список проектов</h2>

      <div class="pf-filters fade-in" role="tablist" aria-label="Фильтр по секторам">
        {filters.map((f, i) => (
          <button
            type="button"
            class:list={["pf-filter", { "is-active": i === 0 }]}
            data-filter={f.key}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            {f.label}
            <span class="pf-filter__count">{f.count}</span>
          </button>
        ))}
      </div>

      <ul class="pf-grid fade-in" id="pf-grid">
        {projects.map((p) => (
          <li data-sector={p.data.sector}>
            <PortfolioCard
              slug={p.data.slug}
              title={p.data.title}
              client={p.data.client}
              year={p.data.year}
              summary={p.data.summary}
              dgu={p.data.dgu}
              sector={p.data.sector}
              award={p.data.award}
            />
          </li>
        ))}
      </ul>

      <p class="pf-empty" id="pf-empty" hidden>В этом секторе пока нет проектов.</p>
    </div>
  </section>

  <FinalCTA
    title="У вас похожий проект?"
    text="Большинство наших проектов начинались с обращения «у нас есть задача, не уверены, реализуема ли она». Опишите вашу ситуацию — оценим возможности и предложим вариант реализации."
  />
</BaseLayout>

<style>
  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
  }

  .pf-stats {
    background: var(--bg-light);
    border-bottom: 1px solid var(--border-light);
    padding-block: clamp(2rem, 3.5vw, 3rem);
  }
  .pf-stats__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .pf-stats__number {
    font-size: clamp(1.5rem, 1.6vw + 1rem, 2.25rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--text-primary);
  }
  .pf-stats__plus { color: var(--brand-accent); margin-left: 0.05em; }
  .pf-stats__label {
    margin-top: 0.5rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .pf-list { background: var(--bg-white); }

  .pf-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }
  .pf-filter {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    background: var(--bg-light);
    border: 1px solid var(--border-light);
    color: var(--text-primary);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .pf-filter:hover {
    border-color: color-mix(in srgb, var(--brand-blue) 30%, var(--border-light));
  }
  .pf-filter.is-active {
    background: var(--brand-blue);
    border-color: var(--brand-blue);
    color: var(--text-on-dark);
  }
  .pf-filter__count {
    font-size: 0.6875rem;
    color: inherit;
    opacity: 0.7;
  }
  .pf-filter.is-active .pf-filter__count { opacity: 0.85; }

  .pf-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .pf-empty {
    text-align: center;
    color: var(--text-secondary);
    padding: 3rem 0;
  }

  @media (max-width: 960px) {
    .pf-stats__grid { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
    .pf-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .pf-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.pf-filter');
  const grid = document.getElementById('pf-grid');
  const empty = document.getElementById('pf-empty');
  if (grid && empty && buttons.length) {
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter ?? 'all';
        buttons.forEach((b) => {
          const active = b === btn;
          b.classList.toggle('is-active', active);
          b.setAttribute('aria-selected', String(active));
        });
        let visible = 0;
        grid.querySelectorAll<HTMLLIElement>('li[data-sector]').forEach((li) => {
          const match = filter === 'all' || li.dataset.sector === filter;
          li.hidden = !match;
          if (match) visible++;
        });
        empty.hidden = visible > 0;
      });
    });
  }
</script>
